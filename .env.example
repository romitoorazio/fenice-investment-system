# Fenice Autonomous Analysis
# Copiare le chiavi nei GitHub Repository Secrets, non commetterle mai nel repository.

# Mercati tradizionali, IPO, ETF, forex, commodities e opzioni
ALPHA_VANTAGE_API_KEY=

# Indicatori macroeconomici FRED
FRED_API_KEY=

# Crypto pubbliche (facoltativa ma raccomandata)
COINGECKO_API_KEY=

# Nuovi token appena aggiunti; richiede piano CoinGecko Pro
COINGECKO_PRO_API_KEY=

# Identificazione richiesta dalla SEC per accesso automatizzato
# Esempio: FeniceInvestmentSystem/1.0 nome@dominio.it
SEC_USER_AGENT=
